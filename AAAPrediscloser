
<!DOCTYPE html>
<html>
<head>
    <title>Pre-Disclosure Request</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f8f9fa;
        }

        .section-title {
            background: #0d6efd;
            color: white;
            padding: 10px;
            font-weight: bold;
        }

        .account-card {
            border: 1px solid #ddd;
            border-radius: 6px;
            margin-bottom: 20px;
            background: white;
        }

        .account-header {
            background: #e9ecef;
            padding: 10px;
            font-weight: bold;
        }

        .required {
            color: red;
        }
    </style>
</head>

<body>

<div class="container-fluid mt-3">

    <!-- HEADER -->

    <div class="card mb-4">

        <div class="section-title">
            PRE-DISCLOSURE REQUEST
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-3 mb-3">
                    <label>Country</label>
                    <input type="text" class="form-control">
                </div>

                <div class="col-md-3 mb-3">
                    <label>Submitted By</label>
                    <input type="text" class="form-control">
                </div>

                <div class="col-md-3 mb-3">
                    <label>Disclosure Type</label>
                    <select class="form-select">
                        <option>Partner / Trade</option>
                        <option>B2B</option>
                        <option>PR & Social</option>
                    </select>
                </div>

                <div class="col-md-3 mb-3">
                    <label>Business Type</label>
                    <select class="form-select">
                        <option>ISB</option>
                        <option>ICB</option>
                        <option>ISB & ICB</option>
                    </select>
                </div>

            </div>

        </div>

    </div>

    <!-- ACCOUNT SECTION -->

    <div class="d-flex justify-content-between mb-3">

        <h4>Accounts</h4>

        <button type="button"
                class="btn btn-primary"
                onclick="addAccount()">
            Add Account
        </button>

    </div>

    <div id="accountContainer">

        <!-- ACCOUNT TEMPLATE -->

        <div class="account-card">

            <div class="account-header">
                Account 1
            </div>

            <div class="p-3">

                <div class="row">

                    <div class="col-md-4 mb-3">
                        <label>Account / Retailer / B2B End User / Media Name</label>
                        <input class="form-control">
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Website URL</label>
                        <input class="form-control">
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>B2B Business Type</label>
                        <input class="form-control">
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-3 mb-3">
                        <label>NDA Available</label>
                        <select class="form-select">
                            <option>Yes</option>
                            <option>No</option>
                        </select>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Pre-Disclosure Format</label>
                        <select class="form-select">
                            <option>1:1 Online</option>
                            <option>1:1 Offline</option>
                            <option>Group Online</option>
                            <option>Group Face-to-Face</option>
                        </select>
                    </div>

                    <div class="col-md-5 mb-3">
                        <label>Reason for Pre-Disclosure</label>
                        <input class="form-control">
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label>Products to be Disclosed</label>
                        <textarea class="form-control"></textarea>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Internal Sales Level</label>
                        <select class="form-select">
                            <option>PL</option>
                            <option>AFI</option>
                            <option>AFI2</option>
                            <option>FIP</option>
                            <option>Trade</option>
                        </select>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-3 mb-3">
                        <label>SDA Partner List</label>
                        <select class="form-select">
                            <option>Yes</option>
                            <option>No</option>
                        </select>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label>Meeting Date</label>
                        <input type="date" class="form-control">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Meeting Location</label>
                        <input class="form-control">
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label>Canon Responsible Person</label>
                        <textarea class="form-control"></textarea>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Individual Being Disclosed To</label>
                        <textarea class="form-control"></textarea>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label>Information to be Disclosed</label>
                        <textarea class="form-control"></textarea>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Retailer Ranking (Trade Only)</label>
                        <input class="form-control">
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-8 mb-3">
                        <label>Business Justification (B2B Only)</label>
                        <textarea class="form-control"></textarea>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Event Planned After Disclosure</label>
                        <select class="form-select">
                            <option>Yes</option>
                            <option>No</option>
                        </select>
                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- BUTTONS -->

    <div class="text-end mb-5">

        <button class="btn btn-secondary">
            Save Draft
        </button>

        <button class="btn btn-success">
            Submit
        </button>

    </div>

</div>

<script>

let accountCount = 1;

function addAccount() {

    accountCount++;

    const firstAccount = document.querySelector('.account-card');

    const clone = firstAccount.cloneNode(true);

    clone.querySelector('.account-header').innerText =
        'Account ' + accountCount;

    clone.querySelectorAll('input, textarea').forEach(el => {
        el.value = '';
    });

    clone.querySelectorAll('select').forEach(el => {
        el.selectedIndex = 0;
    });

    document.getElementById('accountContainer')
        .appendChild(clone);
}

</script>

</body>
</html>
