<!DOCTYPE html>
<html>
<head>
    <title>Pre-Disclosure Request</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            background:#f5f5f5;
        }

        .table-responsive{
            overflow-x:auto;
        }

        table{
            min-width:2600px;
        }

        th{
            white-space:nowrap;
            font-size:13px;
            background:#f8f9fa;
        }

        td{
            min-width:150px;
        }

        .hidden-col{
            display:none;
        }
    </style>
</head>

<body>

<div class="container-fluid mt-3">

    <!-- HEADER -->

    <div class="card mb-3">

        <div class="card-header">
            Pre-Disclosure Request
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-3">
                    <label>Country</label>
                    <input class="form-control">
                </div>

                <div class="col-md-3">
                    <label>Submitted By</label>
                    <input class="form-control">
                </div>

                <div class="col-md-3">
                    <label>Disclosure Type</label>

                    <select id="disclosure_type"
                            class="form-select"
                            onchange="toggleFields()">

                        <option value="trade">Trade</option>
                        <option value="b2b">B2B</option>
                        <option value="pr">PR & Social</option>

                    </select>
                </div>

                <div class="col-md-3">
                    <label>Business Type</label>

                    <select class="form-select">
                        <option>ISB</option>
                        <option>ICB</option>
                        <option>ISB & ICB</option>
                    </select>
                </div>

            </div>

        </div>

    </div>

    <!-- LINE ITEMS -->

    <div class="card">

        <div class="card-header d-flex justify-content-between">

            <span>Account Details</span>

            <button type="button"
                    class="btn btn-primary btn-sm"
                    onclick="addRow()">

                Add Account

            </button>

        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-bordered table-sm">

                    <thead>

                    <tr>

                        <th>Account Name</th>
                        <th>Website URL</th>

                        <th class="b2b-col">
                            B2B Business Type
                        </th>

                        <th>NDA</th>

                        <th>Pre-Disclosure Format</th>

                        <th>Reason</th>

                        <th>Products</th>

                        <th>Sales Level</th>

                        <th class="trade-col">
                            SDA Partner List
                        </th>

                        <th>Meeting Date</th>

                        <th>Meeting Location</th>

                        <th>Canon Responsible Person</th>

                        <th>Disclosed To</th>

                        <th>Information Disclosed</th>

                        <th class="trade-col">
                            Retailer Ranking
                        </th>

                        <th class="b2b-col">
                            Volume of Business
                        </th>

                        <th class="b2b-col">
                            Previously Pre-Disclosed
                        </th>

                        <th>Action</th>

                    </tr>

                    </thead>

                    <tbody id="lineTable">

                    <tr>

                        <td>
                            <input class="form-control">
                        </td>

                        <td>
                            <input class="form-control">
                        </td>

                        <td class="b2b-col">
                            <input class="form-control">
                        </td>

                        <td>
                            <select class="form-select">
                                <option>Yes</option>
                                <option>No</option>
                            </select>
                        </td>

                        <td>
                            <select class="form-select">
                                <option>1:1 Online</option>
                                <option>1:1 Offline</option>
                                <option>Group Online</option>
                                <option>Group Face-to-Face</option>
                            </select>
                        </td>

                        <td>
                            <input class="form-control">
                        </td>

                        <td>
                            <input class="form-control">
                        </td>

                        <td>
                            <select class="form-select">
                                <option>PL</option>
                                <option>AFI</option>
                                <option>AFI2</option>
                                <option>FIP</option>
                                <option>Trade</option>
                            </select>
                        </td>

                        <td class="trade-col">
                            <select class="form-select">
                                <option>Yes</option>
                                <option>No</option>
                            </select>
                        </td>

                        <td>
                            <input type="date" class="form-control">
                        </td>

                        <td>
                            <input class="form-control">
                        </td>

                        <td>
                            <input class="form-control">
                        </td>

                        <td>
                            <input class="form-control">
                        </td>

                        <td>
                            <input class="form-control">
                        </td>

                        <td class="trade-col">
                            <input class="form-control">
                        </td>

                        <td class="b2b-col">
                            <input class="form-control">
                        </td>

                        <td class="b2b-col">
                            <select class="form-select">
                                <option>Yes</option>
                                <option>No</option>
                            </select>
                        </td>

                        <td>
                            <button type="button"
                                    class="btn btn-danger btn-sm"
                                    onclick="deleteRow(this)">
                                Delete
                            </button>
                        </td>

                    </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<script>

function addRow(){

    let tbody = document.getElementById("lineTable");

    let row = tbody.rows[0].cloneNode(true);

    row.querySelectorAll("input").forEach(
        e => e.value = ""
    );

    row.querySelectorAll("select").forEach(
        e => e.selectedIndex = 0
    );

    tbody.appendChild(row);

    toggleFields();
}

function deleteRow(btn){

    let tbody = document.getElementById("lineTable");

    if(tbody.rows.length > 1){
        btn.closest("tr").remove();
    }
}

function toggleFields(){

    let type =
        document.getElementById("disclosure_type").value;

    let tradeCols =
        document.querySelectorAll(".trade-col");

    let b2bCols =
        document.querySelectorAll(".b2b-col");

    if(type === "trade"){

        tradeCols.forEach(
            c => c.style.display = ""
        );

        b2bCols.forEach(
            c => c.style.display = "none"
        );
    }

    else if(type === "b2b"){

        tradeCols.forEach(
            c => c.style.display = "none"
        );

        b2bCols.forEach(
            c => c.style.display = ""
        );
    }

    else{

        tradeCols.forEach(
            c => c.style.display = "none"
        );

        b2bCols.forEach(
            c => c.style.display = "none"
        );
    }
}

toggleFields();

</script>

</body>
</html>
