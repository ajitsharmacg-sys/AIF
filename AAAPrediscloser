<script>

function addRow() {

    let tbody = document.getElementById("lineItems");

    let row = tbody.rows[0].cloneNode(true);

    row.querySelectorAll("input").forEach(function(el) {
        el.value = "";
    });

    row.querySelectorAll("select").forEach(function(el) {
        el.selectedIndex = 0;
    });

    tbody.appendChild(row);

    toggleFields();
}

function deleteRow(btn) {

    let tbody = document.getElementById("lineItems");

    if (tbody.rows.length > 1) {
        btn.closest("tr").remove();
    }
}

function toggleFields() {

    let type =
        document.getElementById("disclosureType").value;

    let tradeCols =
        document.querySelectorAll(".trade-col");

    let b2bCols =
        document.querySelectorAll(".b2b-col");

    if (type === "trade") {

        tradeCols.forEach(col => {
            col.style.display = "";
        });

        b2bCols.forEach(col => {
            col.style.display = "none";
        });
    }

    else if (type === "b2b") {

        tradeCols.forEach(col => {
            col.style.display = "none";
        });

        b2bCols.forEach(col => {
            col.style.display = "";
        });
    }

    else {

        tradeCols.forEach(col => {
            col.style.display = "none";
        });

        b2bCols.forEach(col => {
            col.style.display = "none";
        });
    }
}

