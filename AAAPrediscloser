<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pre-Disclosure Request</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f5f5f5;
        }

        .card-header {
            font-weight: 600;
        }

        .table-responsive {
            overflow-x: auto;
        }

        table {
            min-width: 2800px;
        }

        th {
            white-space: nowrap;
            font-size: 13px;
            background: #f8f9fa;
        }

        td {
            min-width: 150px;
        }

        .action-col {
            min-width: 80px;
        }
    </style>
</head>

<body>

<div class="container-fluid mt-3">

    <!-- HEADER -->

    <div class="card mb-3">

        <div class="card-header">
            Pre-Disclosure Request
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-3 mb-3">
                    <label class="form-label">Country</label>
                    <input type="text" class="form-control">
                </div>

                <div class="col-md-3 mb-3">
                    <label class="form-label">Submitted By</label>
                    <input type="text" class="form-control">
                </div>

                <div class="col-md-3 mb-3">
                    <label class="form-label">Disclosure Type</label>
                    <select class="form-select">
                        <option>Partner / Trade</option>
                        <option>B2B</option>
                        <option>PR & Social</option>
                    </select>
                </div>

                <div class="col-md-3 mb-3">
                    <label class="form-label">Business Type</label>
                    <select class="form-select">
                        <option>ISB</option>
                        <option>ICB</option>
                        <option>ISB & ICB</option>
                    </select>
                </div>

            </div>

        </div>

    </div>

    <!-- LINE ITEMS -->

    <div class="card">

        <div class="card-header d-flex justify-content-between align-items-center">

            <span>Account Details</span>

            <button type="button"
                    class="btn btn-primary btn-sm"
                    onclick="addRow()">
                Add Account
            </button>

        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-bordered table-sm align-middle">

                    <thead>

                    <tr>
                        <th>Account Name</th>
                        <th>Website URL</th>
                        <th>B2B Business Type</th>
                        <th>NDA</th>
                        <th>Pre-Disclosure Format</th>
                        <th>Reason for Disclosure</th>
                        <th>Products to be Disclosed</th>
                        <th>Internal Sales Level</th>
                        <th>SDA Partner List</th>
                        <th>Meeting Date</th>
                        <th>Meeting Location</th>
                        <th>Canon Responsible Person</th>
                        <th>Individual Being Disclosed To</th>
                        <th>Information to be Disclosed</th>
                        <th>Retailer Ranking</th>
                        <th>Business Justification</th>
                        <th>Event Planned After Disclosure</th>
                        <th class="action-col">Action</th>
                    </tr>

                    </thead>

                    <tbody id="accountTableBody">

                    <tr>

                        <td><input type="text" class="form-control"></td>

                        <td><input type="text" class="form-control"></td>

                        <td><input type="text" class="form-control"></td>

                        <td>
                            <select class="form-select">
                                <option>Yes</option>
                                <option>No</option>
                            </select>
                        </td>

                        <td>
                            <select class="form-select">
                                <option>1:1 Online</option>
                                <option>1:1 Offline</option>
                                <option>Group Online</option>
                                <option>Group Face-to-Face</option>
                            </select>
                        </td>

                        <td><input type="text" class="form-control"></td>

                        <td><input type="text" class="form-control"></td>

                        <td>
                            <select class="form-select">
                                <option>PL</option>
                                <option>AFI</option>
                                <option>AFI2</option>
                                <option>FIP</option>
                                <option>Trade</option>
                            </select>
                        </td>

                        <td>
                            <select class="form-select">
                                <option>Yes</option>
                                <option>No</option>
                            </select>
                        </td>

                        <td>
                            <input type="date" class="form-control">
                        </td>

                        <td>
                            <input type="text" class="form-control">
                        </td>

                        <td>
                            <input type="text" class="form-control">
                        </td>

                        <td>
                            <input type="text" class="form-control">
                        </td>

                        <td>
                            <input type="text" class="form-control">
                        </td>

                        <td>
                            <input type="text" class="form-control">
                        </td>

                        <td>
                            <input type="text" class="form-control">
                        </td>

                        <td>
                            <select class="form-select">
                                <option>Yes</option>
                                <option>No</option>
                            </select>
                        </td>

                        <td>
                            <button type="button"
                                    class="btn btn-danger btn-sm"
                                    onclick="deleteRow(this)">
                                Delete
                            </button>
                        </td>

                    </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <div class="text-end mt-3 mb-5">

        <button class="btn btn-secondary">
            Save Draft
        </button>

        <button class="btn btn-success">
            Submit
        </button>

    </div>

</div>

<script>

function addRow() {

    let tbody = document.getElementById("accountTableBody");

    let row = tbody.rows[0].cloneNode(true);

    row.querySelectorAll("input").forEach(function(input) {
        input.value = "";
    });

    row.querySelectorAll("select").forEach(function(select) {
        select.selectedIndex = 0;
    });

    tbody.appendChild(row);
}

function deleteRow(button) {

    let tbody = document.getElementById("accountTableBody");

    if (tbody.rows.length > 1) {
        button.closest("tr").remove();
    } else {
        alert("At least one account row is required.");
    }
}

</script>

</body>
</html>
