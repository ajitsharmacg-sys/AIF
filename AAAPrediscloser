def get_conflicting_aif_ids(aif):
    base_sql = """
        SELECT
            a.aif_id,
            a.start_date,
            a.end_date,
            l.mercury_code,
            l.promotional_elp,
            {customer_column}
        FROM aif_aif a
        INNER JOIN aif_aiflines l
            ON l.aif_id = a.aif_id

        INNER JOIN aif_aiflines current_l
            ON current_l.aif_id = %s
            AND current_l.mercury_code = l.mercury_code

        {customer_join}

        WHERE
            a.aif_id != %s
            AND a.nso = %s
            AND a.end_date >= %s
            AND (
                SELECT TOP 1 status
                FROM aif_aifstatus s
                WHERE s.aif_id = a.aif_id
                ORDER BY s.id DESC
            ) != %s
            {extra_condition}
    """

    # ALL NSO CASE (NO CUSTOMER)
    if aif.is_all_nso_enabled:
        customer_column = "NULL as customer"
        customer_join = ""
        extra_condition = "AND a.is_all_nso_enabled = 1"

        params = [
            aif.aif_id,                    # current_l
            aif.aif_id,                    # exclude self
            aif.nso,
            aif.start_date,
            AifStatusChoices.INVALID,      # exclude invalid AIFs
        ]

    # CUSTOMER CASE
    else:
        customer_column = "c.oracle_cust_number as customer"
        customer_join = """
            INNER JOIN aif_aifcustomerlines c
                ON c.aif_id = a.aif_id
            INNER JOIN aif_aifcustomerlines current_c
                ON current_c.aif_id = %s
                AND current_c.oracle_cust_number = c.oracle_cust_number
        """
        extra_condition = ""

        params = [
            aif.aif_id,                    # current_l
            aif.aif_id,                    # current_c
            aif.aif_id,                    # exclude self
            aif.nso,
            aif.start_date,
            AifStatusChoices.INVALID,      # exclude invalid AIFs
        ]

    sql = base_sql.format(
        customer_column=customer_column,
        customer_join=customer_join,
        extra_condition=extra_condition,
    )

    with connection.cursor() as cursor:
        cursor.execute(sql, params)
        columns = [col[0] for col in cursor.description]
        rows = cursor.fetchall()

    return [dict(zip(columns, row)) for row in rows]












is_date_valid_for_pricelist(t_ticket) {

    const rules = [
        {
            fields: ["pelp_price"],
            date: t_ticket.elp_start_date,
            label: "ELP"
        },
        {
            fields: ["cee_price", "cea_price", "cme_price", "csa_price"],
            date: t_ticket.cif_start_date,
            label: "CIF"
        },
        {
            fields: ["rsp_baseline", "rsp_price"],
            date: t_ticket.ecom_launch_date,
            label: "Ecom Launch"
        },
        {
            fields: ["tp_price"],
            date: t_ticket.tp_launch_date,
            label: "Transfer Price"
        },
        {
            fields: ["influencer_price"],
            date: t_ticket.influencer_start_date,
            label: "INFL"
        }
    ];

    const isValid = val =>
        val !== null && val !== "" && val !== undefined;

    for (let i = 0; i < this.lines.length; i++) {

        const line = this.lines[i];

        for (const { fields, date, label } of rules) {

            const hasDate = isValid(date);

            const hasPrice = fields.some(field =>
                isValid(line[field])
            );

            if (hasDate !== hasPrice) {

                this.dialog
                    .reset_to_default()
                    .set_title("Failed")
                    .set_message(
                        `${label} date field and price field do not match for line ${i + 1}.`
                    )
                    .set_true_action("Close")
                    .show();

                return false;
            }
        }
    }

    return true;
}



validate_pricelist(line_item) {
    const priceMap = {
        pelp_price: "pelp",
        cee_price: "cee",
        cea_price: "cea",
        cme_price: "cme",
        csa_price: "csa",
        tp_price: "tp",
        rsp_baseline: "rsp_baseline",
        rsp_price: "rsp",
        influencer_price: "infl"
    };

    const isValid = val =>
        val !== null && val !== "" && val !== undefined;

    for (let i = 0; i < line_item.length; i++) {

        const line = line_item[i];
        let hasPrice = false;

        for (const [field, type] of Object.entries(priceMap)) {

            if (isValid(line[field])) {

                hasPrice = true;

                if (!this.pricelist.includes(type)) {
                    this.pricelist.push(type);
                }
            }
        }

        if (!hasPrice) {
            this.dialog
                .reset_to_default()
                .set_title("Failed")
                .set_message(`Please enter at least one price in line ${i + 1}.`)
                .set_true_action("Close")
                .show();

            return false;
        }
    }

    return true;
}

if (!this.validate_pricelist(this.lines)) {
