def get_queryset(self):
    user = self.request.user

    # 🔹 For PATCH / GET single object / DELETE → don't restrict queryset
    if self.action in ["retrieve", "update", "partial_update", "destroy"]:
        return AifLines.objects.all()

    # 🔹 From here → only LIST action
    aif_id = self.request.query_params.get("aif")

    if not aif_id:
        return AifLines.objects.none()

    aif = Aif.objects.filter(aif_id=aif_id).first()
    if not aif:
        return AifLines.objects.none()

    # 🔹 If NOT PSBD → return all lines for that AIF
    if not user.groups.filter(name=PSBD_TEAM_USER).exists():
        return AifLines.objects.filter(aif=aif)

    # 🔹 PSBD users → restrict by responsibility
    responsibility = PROMOTION_CATEGORY_TO_RESPONSIBILITY.get(
        aif.promotion_category
    )

    allowed_groups = AifApprover.objects.filter(
        approver=user,
        responsibility=responsibility
    ).values_list("product_group", flat=True)

    return AifLines.objects.filter(
        aif=aif,
        product_group__in=allowed_groups
    )


def get_queryset(self):
    user = self.request.user
    aif_id = self.request.query_params.get("aif")

    base_qs = AifLines.objects.all()

    if not aif_id:
        return base_qs.none()

    # If user is NOT PSBD user → no restriction
    if not user.groups.filter(name=PSBD_TEAM_USER).exists():
        return base_qs.filter(aif=aif_id)

    # 🔹 Get AIF object
    try:
        aif = Aif.objects.get(id=aif_id)
    except Aif.DoesNotExist:
        return base_qs.none()

    # 🔹 Map promotion_category → responsibility
    responsibility = self.PROMOTION_CATEGORY_TO_RESPONSIBILITY.get(
        aif.promotion_category
    )

    # 🔹 Filter approver by BOTH product_group and responsibility
    allowed_groups = AifApprover.objects.filter(
        approver=user,
        responsibility=responsibility
    ).values_list("product_group", flat=True)

    return base_qs.filter(
        aif=aif_id,
        product_group__in=allowed_groups
    )








