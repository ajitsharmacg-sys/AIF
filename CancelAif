validate_customer_lines() {

    // If All NSO is enabled → no customer validation required
    if (this.isAllNSOMarketEnabled) {
        return true;
    }

    // If All NSO is false → customer must exist
    if (!this.customer_lines || this.customer_lines.length === 0) {
        this.dialog
            .reset_to_default()
            .set_title("Customer Required")
            .set_message("At least one customer must be entered when 'All NSO Market' is disabled.")
            .set_true_action("Close")
            .show();

        return false;
    }

    // Check blank customer numbers
    for (const line of this.customer_lines) {
        if (!line.oracle_cust_number || line.oracle_cust_number.trim() === "") {
            this.dialog
                .reset_to_default()
                .set_title("Customer Required")
                .set_message("Customer Number cannot be empty.")
                .set_true_action("Close")
                .show();

            return false;
        }
    }

    return true;
}


