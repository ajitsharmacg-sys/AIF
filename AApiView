class PreDisclosureView(viewsets.ModelViewSet):
    permission_classes = [IsApplicationUser]

    pagination_class = StandardPagination

    filter_backends = [
        DjangoFilterBackend,
        filters.SearchFilter,
        filters.OrderingFilter,
        PreDisclosureByStatusFilter,
    ]

    filterset_fields = {
        "predisclosure_id": ["exact"],
        "region": ["exact"],
        "predisclosure_type": ["exact"],
        "product_category": ["exact"],
        "meta_created_date": ["exact", "gt", "lt", "gte", "lte"],
    }

    search_fields = [
        "predisclosure_id",
        "region",
    ]

    ordering_fields = "__all__"

    ordering = ("predisclosure_id",)

    def get_serializer_class(self):
        if self.action in [
            "create",
            "update",
            "partial_update",
            "destroy",
        ]:
            return PreDisclosureWriteSerializer

        return PreDisclosureReadSerializer

    def get_queryset(self):

        if self.request.user.groups.filter(name=NSO_USER).exists():

            return PreDisclosure.objects.filter(
                region__in=Organization.objects.filter(
                    cluster=self.request.user.cluster
                ).values_list(
                    "organization_name",
                    flat=True,
                )
            )

        return PreDisclosure.objects.all()

    def perform_create(self, serializer):

        instance = serializer.save(
            meta_created_by=self.request.user,
        )

        PreDisclosureStatus.objects.create(
            predisclosure=instance,
            status=PreDisclosureStatusChoices.DRAFT,
            meta_created_by=self.request.user,
        )

        return instance

    def perform_update(self, serializer):

        predisclosure_status = get_predisclosure_status(
            self.kwargs["pk"]
        )

        if predisclosure_status.status not in [
            PreDisclosureStatusChoices.DRAFT,
            PreDisclosureStatusChoices.REJECTED,
        ]:
            raise PermissionDenied(
                "You cannot edit this request."
            )

        instance = serializer.save(
            meta_edited_by=self.request.user,
            meta_edited_date=timezone.now(),
        )

        # Reset rejected request back to Draft
        if (
            predisclosure_status.status
            == PreDisclosureStatusChoices.REJECTED
        ):

            PreDisclosureStatus.objects.create(
                predisclosure=instance,
                status=PreDisclosureStatusChoices.DRAFT,
                meta_created_by=self.request.user,
            )

            update_all_lines_status(
                status=PreDisclosureLineStatusChoices.DRAFT,
                predisclosure=instance,
                request=self.request,
            )

        return instance

    def perform_destroy(self, instance):

        predisclosure_status = get_predisclosure_status(
            instance.predisclosure_id
        )

        if predisclosure_status.status in [
            PreDisclosureStatusChoices.DRAFT,
            PreDisclosureStatusChoices.REJECTED,
        ]:
            return super().perform_destroy(instance)

        if self.request.user.groups.filter(
            name=ADMIN_ROLE
        ).exists():
            return super().perform_destroy(instance)

        raise PermissionDenied(
            f"Only {ADMIN_ROLE} can delete this request."
        )


class PreDisclosureStatusView(viewsets.ModelViewSet):
    permission_classes = [IsApplicationUser]

    queryset = PreDisclosureStatus.objects.all()

    serializer_class = PreDisclosureStatusSerializer

    filter_backends = [
        DjangoFilterBackend,
        filters.SearchFilter,
        filters.OrderingFilter,
    ]

    ordering_fields = "__all__"

    ordering = ("-meta_created_date",)

    filterset_fields = {
        "predisclosure": ["exact"],
    }

    def perform_create(self, serializer):

        instance = serializer.save(
            meta_created_by=self.request.user,
        )

        # User submits the request
        if instance.status == PreDisclosureStatusChoices.IN_PROGRESS:

            set_initial_line_status(
                instance.predisclosure,
                self.request,
            )

        # COMPLETED and REJECTED are created
        # automatically by the workflow engine.
        return instance

    def perform_update(self, serializer):
        raise PermissionDenied(
            "Status history cannot be updated."
        )

    def perform_destroy(self, instance):
        raise PermissionDenied(
            "Status history cannot be deleted."
        )
