    product_category = models.CharField(
        max_length=20,
        choices=[
            ("ISB", "ISB"),
            ("ICB", "ICB"),
        ],
    )

    product_name = models.CharField(
        max_length=200,
        unique=True,
    )

    is_active = models.BooleanField(
        default=True,
    )

    display_order = models.PositiveIntegerField(
        default=1,
    )

    def __str__(self):
        return self.product_name


products = models.ManyToManyField(
