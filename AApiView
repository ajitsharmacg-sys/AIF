multiple_line_status_choices() {

    if (this.selected_lines.length === 0) {
        return [];
    }

    let common_target_status = new Set(
        this.get_line_status_choices(
            this.selected_lines[0]
        )
    );

    for (const line of this.selected_lines.slice(1)) {

        common_target_status =
            common_target_status.intersection(
                new Set(
                    this.get_line_status_choices(line)
                )
            );

    }

    return [...common_target_status];

},

get_line_status_choices(line) {

    const current_status = line.predisclosure_line_status;

    if (!current_status) {
        return [];
    }

    const allowed_roles =
        this.LINE_STATUS_TO_ROLE[current_status];

    if (!allowed_roles) {
        return [];
    }

    const has_permission = allowed_roles.some(role =>
        this.user_role.includes(role)
    );

    if (!has_permission) {
        return [];
    }

    // Every awaiting stage only exposes Approve/Reject
    if (current_status.startsWith("AWAITING_")) {

        return [
            "APPROVED",
            "REJECTED",
        ];

    }

    return [];

},

