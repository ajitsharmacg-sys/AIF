def perform_create(self, serializer):

    line = serializer.validated_data["line"]

    latest_status = (
        PreDisclosureLineStatus.objects.filter(
            line=line
        ).latest("meta_created_date")
    )

    allowed_roles = get_role_from_status(latest_status.status)

    if not self.request.user.groups.filter(
        name__in=allowed_roles
    ).exists():
        raise PermissionDenied(
            "You are not authorized to approve this line."
        )

    instance = serializer.save(
        meta_created_by=self.request.user,
    )

    process_line_approval(
        self.request,
        instance,
    )


