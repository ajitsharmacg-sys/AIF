class PreDisclosureProductView(viewsets.ReadOnlyModelViewSet):

    serializer_class = PreDisclosureProductSerializer

    def get_queryset(self):

        category = self.request.query_params.get(
            "product_category"
        )

        queryset = PreDisclosureProduct.objects.filter(
            is_active=True,
        )

        if category == ProductCategoryChoices.ISB:
            return queryset.filter(
                product_category=ProductCategoryChoices.ISB
            )

        if category == ProductCategoryChoices.ICB:
            return queryset.filter(
                product_category=ProductCategoryChoices.ICB
            )

        if category == ProductCategoryChoices.ISB_ICB:
            return queryset.filter(
                product_category__in=[
                    ProductCategoryChoices.ISB,
                    ProductCategoryChoices.ICB,
                ]
            )

        return queryset.none()


