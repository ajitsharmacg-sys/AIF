import { deleteRequest } from "{% static 'common/modules/common.js' %}";
import { utils, writeFile } from "{% static 'common/modules/xlsx.mjs' %}";
import * as vuejs_components from "{% static 'common/modules/components.js' %}";

const list_of_predisclosures = Vue.createApp({

    delimiters: ['[[', ']]'],

    data() {

        return {

            nav_state: init_nav_state,

            query_filter: "",

            columns: [
                "meta_created_date",
                "predisclosure_id",
                "region",
                "predisclosure_type",
                "product_category",
                "link",
                "predisclosure_status",
            ],

            selected_predisclosure: selected_predisclosure,

            show_notification_dialog: false,

            notification_message: "",

            update_triggered: false,

        };

    },

    computed: {

        filter_items() {

            const res = [];

            res.push({
                label: "ALL",
                expression: "&predisclosure_status="
            });

            for (const status of [
                "DRAFT",
                "IN_PROGRESS",
                "REJECTED",
                "COMPLETED"
            ]) {

                res.push({
                    label: status,
                    expression:
                        "&predisclosure_status=" + status,
                });

            }

            return res;

        },

        custom_format() {

            return {

                predisclosure_status: {

                    DRAFT: "text-bg-secondary",

                    IN_PROGRESS: "text-bg-warning",

                    REJECTED: "text-bg-danger",

                    COMPLETED: "text-bg-success",

                }

            };

        },

    },

    methods: {

        show_notification(message) {

            this.notification_message = message;

            this.show_notification_dialog = true;

        },

        display_error(error_response) {

            try {

                error_response.json().then(data => {

                    this.show_notification(data);

                });

            }

            catch {

                this.show_notification(
                    "Unknown error occurred. Please contact the Support Team."
                );

            }

        },

        delete_predisclosure(item) {

            deleteRequest(
                api_endpoints.predisclosure +
                item.predisclosure_id +
                "/"
            )

            .then(response => {

                if (response.ok) {

                    return response;

                }

                return Promise.reject(response);

            })

            .then(() => {

                this.update_triggered = true;

                this.show_notification(
                    "PreDisclosure deleted successfully."
                );

            })

            .catch(error_response => {

                this.display_error(error_response);

            });

        },

        navigate(id, context = null) {

            this.nav_state.list_of_predisclosures = false;

            this.nav_state.current = id;

            this.nav_state[id] = true;

            this.nav_state.previous =
                "list_of_predisclosures";

            this.nav_state.context = context;

        },

        async select_predisclosure_and_navigate(
            item,
            next_view_id,
            context = null
        ) {

            if (context === "template") {

                this.selected_predisclosure = {
                    ...item,
                };

            }

            else {

                this.selected_predisclosure = item;

            }

            this.navigate(
                next_view_id,
                context,
            );

        },

        async export_to_excel(items) {

            this.show_notification(
                "Only current page has been exported."
            );

            const workbook = utils.book_new();

            const worksheet =
                utils.json_to_sheet(items?.results);

            utils.book_append_sheet(
                workbook,
                worksheet,
                "PreDisclosures",
            );

            writeFile(
                workbook,
                "PreDisclosures.xlsx",
            );

        },

    },

});

