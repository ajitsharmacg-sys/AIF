async delete_lines() {
    for (const lineid of this.changes.deleted_lines) {

        // ✅ skip new lines
        if (!lineid) continue;

        await deleteRequest(api_endpoints.aif_lines + lineid + "/")
            .catch(error_response => {
                this.display_error(error_response);
            });
    }
}
