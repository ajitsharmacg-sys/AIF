            AND a.end_date >= %s
            AND a.aif_id != %s
            AND c.oracle_cust_number IN %s
            AND l.mercury_code IN %s
        LIMIT {limit}
    """

    params = [
        aif.nso,
        aif.end_date,
        aif.start_date,
        aif.aif_id,
        tuple(customers),
        tuple(mercury_codes),
    ]

