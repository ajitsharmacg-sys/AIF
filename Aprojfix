delete_customer_line(line) {
    const index = this.customer_lines.indexOf(line);

    if (line.id) {
        this.customer_changes.deleted_cust_lines.add(line.id);
    }

    this.customer_lines.splice(index, 1);
}

create_new_customer_lines()

if (line.id !== null) continue;

patch_customer_lines()

for (const lineid of this.customer_changes.edited_cust_lines) {

    if (!lineid) continue; // skip new rows

    if (this.customer_changes.deleted_cust_lines.has(lineid)) continue;

    for (const line of this.customer_lines) {
        if (lineid === line.id) {
            await patchData(api_endpoints.aif_customer_line + lineid + "/", line)
                .catch(error_response => {
                    error_occured = true;
                    this.display_error(error_response);
                });
        }
    }
}


