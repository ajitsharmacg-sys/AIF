add_customer_line() {
    if (this.isAllNSOMarketEnabled) return;

    const newLine = {
        id: null,
        oracle_cust_number: "",
        oracle_cust_name: ""
    };

    this.customer_lines.push(newLine);
}

<template v-for="(line, lineIndex) in customer_lines" :key="line.id || lineIndex">
v-model="customer_lines[lineIndex].oracle_cust_number"
v-model="customer_lines[lineIndex].oracle_cust_name"


onNSOMarketSelect() {

    if (this.isAllNSOMarketEnabled) {

        this.customer_lines.forEach(line => {
            if (line.id) {
                this.customer_changes.deleted_cust_lines.add(line.id);
            }
        });

        this.aif.aif_customer_lines = [];

    } else {

        if (!this.customer_lines || this.customer_lines.length === 0) {
            this.aif.aif_customer_lines = [{
                id: null,
                oracle_cust_number: "",
                oracle_cust_name: ""
            }];
        }
    }

    this.customer_changes.edited_cust_lines = new Set([]);
}

