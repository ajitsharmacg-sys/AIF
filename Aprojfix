async delete_customer_lines() {
    for (const lineid of this.customer_changes.deleted_cust_lines) {
        if (lineid) {
            await deleteRequest(api_endpoints.aif_customer_line + lineid + "/")
                .catch(error_response => {
                    this.display_error(error_response);
                });
        }
    }
}

