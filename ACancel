async getConflictingRows(aifId) {
  const res = await fetch(`/aifmgmt/api/v1/aif/${aifId}/conflicts/`);
  const data = await res.json();
  return data.conflicting_rows || [];
}



buildConflictAIFStructure(rows) {
  const aifMap = {};

  rows.forEach(row => {
    const {
      aif_id,
      start_date,
      end_date,
      mercury_code,
      promotional_elp,
      customer
    } = row;

    if (!aifMap[aif_id]) {
      aifMap[aif_id] = {
        aif_id,
        start_date,
        end_date,
        aif_lines: [],
        aif_customer_lines: []
      };
    }

    // add line (avoid duplicate)
    const lineExists = aifMap[aif_id].aif_lines.some(
      l =>
        l.mercury_code === mercury_code &&
        l.promotional_elp === promotional_elp
    );

    if (!lineExists) {
      aifMap[aif_id].aif_lines.push({
        mercury_code,
        promotional_elp
      });
    }

    // add customer
    if (customer) {
      const exists = aifMap[aif_id].aif_customer_lines.some(
        c => c.oracle_cust_number === customer
      );

      if (!exists) {
        aifMap[aif_id].aif_customer_lines.push({
          oracle_cust_number: customer
        });
      }
    }
  });

  return Object.values(aifMap);
}


async generateWebEDIHeaderFile(aif) {
  this.ws_data = [];
  this.ws_data.push(this.webedi_header);

  // =========================
  // 🔹 1. CANCELLED AIF
  // =========================
  const cancelledIds = (aif.aif_cancel_numbers || "")
    .split(";")
    .map(v => v.trim())
    .filter(Boolean);

  if (cancelledIds.length > 0) {
    const cancelledAifs = await this.load_aifs_for_cancellation(cancelledIds);

    for (const cancelledAif of cancelledAifs) {
      await this.buildWebEDIHeaderRows({ sourceAIF: cancelledAif, effectiveAIF: aif, trxType: "UPDATE" });
      await this.buildWebEDIHeaderRows({ sourceAIF: cancelledAif, effectiveAIF: aif, trxType: "INSERT" });
    }
  }

  // =========================
  // 🔥 2. CONFLICT AIF (NEW)
  // =========================
  const rows = await this.getConflictingRows(aif.aif_id);
  const conflictAifs = this.buildConflictAIFStructure(rows);

  for (const conflictAif of conflictAifs) {
    await this.buildWebEDIHeaderRows({
      sourceAIF: conflictAif,
      effectiveAIF: aif,
      trxType: "UPDATE"
    });

    await this.buildWebEDIHeaderRows({
      sourceAIF: conflictAif,
      effectiveAIF: aif,
      trxType: "INSERT"
    });
  }

  // =========================
  // 🔹 3. CURRENT AIF
  // =========================
  await this.buildWebEDIHeaderRows({
    sourceAIF: aif,
    effectiveAIF: aif,
    trxType: "INSERT"
  });

  // =========================
  // EXPORT
  // =========================
  const wb = utils.book_new();
  const ws = utils.aoa_to_sheet(this.ws_data);
  utils.book_append_sheet(wb, ws, "Header");

  writeFile(
    wb,
    `WebADI_AIF_${aif.aif_id}_Header_Set_${this.getCurrentDateTimeForFile()}.xlsx`
  );
}
