def get_conflicting_aif_rows(aif):

    base_sql = """
        SELECT 
            a.aif_id,
            a.start_date,
            a.end_date,
            l.mercury_code,
            l.promotional_elp,
            {customer_column}
        FROM aif_aif a
        INNER JOIN aif_aiflines l ON l.aif_id = a.aif_id

        INNER JOIN aif_aiflines current_l
            ON current_l.aif_id = %s
            AND current_l.mercury_code = l.mercury_code

        {customer_join}

        WHERE
            a.aif_id != %s
            AND a.nso = %s
            AND a.start_date > %s
            AND a.start_date < %s
            {extra_condition}
    """

    # --------------------------
    # GLOBAL CASE (NO CUSTOMER)
    # --------------------------
    if aif.is_all_nso_enabled:
        customer_column = "NULL as customer"
        customer_join = ""
        extra_condition = "AND a.is_all_nso_enabled = 1"

        params = [
            aif.aif_id,     # current_l
            aif.aif_id,     # exclude self
            aif.nso,
            aif.start_date, # >
            aif.end_date,   # <
        ]

    # --------------------------
    # CUSTOMER CASE
    # --------------------------
    else:
        customer_column = "c.oracle_cust_number as customer"
        customer_join = """
            INNER JOIN aif_aifcustomerlines c ON c.aif_id = a.aif_id
            INNER JOIN aif_aifcustomerlines current_c
                ON current_c.aif_id = %s
                AND current_c.oracle_cust_number = c.oracle_cust_number
        """
        extra_condition = ""

        params = [
            aif.aif_id,     # current_l
            aif.aif_id,     # current_c
            aif.aif_id,     # exclude self
            aif.nso,
            aif.start_date, # >
            aif.end_date,   # <
        ]

    # --------------------------
    # BUILD FINAL SQL
    # --------------------------
    sql = base_sql.format(
        customer_column=customer_column,
        customer_join=customer_join,
        extra_condition=extra_condition,
    )

    # --------------------------
    # EXECUTE
    # --------------------------
    with connection.cursor() as cursor:
        cursor.execute(sql, params)
        columns = [col[0] for col in cursor.description]
        rows = cursor.fetchall()

    # --------------------------
    # RETURN AS DICT
    # --------------------------
    return [dict(zip(columns, row)) for row in rows]









from django.db import connection

def get_conflicting_aif_rows(aif):

    if aif.is_all_nso_enabled:
        sql = """
            SELECT 
                a.aif_id,
                a.start_date,
                a.end_date,
                l.mercury_code,
                l.promotional_elp,
                NULL as customer
            FROM aif_aif a
            INNER JOIN aif_aiflines l ON l.aif_id = a.aif_id

            INNER JOIN aif_aiflines current_l
                ON current_l.aif_id = %s
                AND current_l.mercury_code = l.mercury_code

            WHERE
                a.aif_id != %s
                AND a.is_all_nso_enabled = 1
                AND a.nso = %s
                AND a.start_date <= %s
                AND a.end_date >= %s
        """

        params = [
            aif.aif_id,
            aif.aif_id,
            aif.nso,
            aif.end_date,
            aif.start_date,
        ]

    else:
        sql = """
            SELECT 
                a.aif_id,
                a.start_date,
                a.end_date,
                l.mercury_code,
                l.promotional_elp,
                c.oracle_cust_number
            FROM aif_aif a
            INNER JOIN aif_aiflines l ON l.aif_id = a.aif_id
            INNER JOIN aif_aifcustomerlines c ON c.aif_id = a.aif_id

            INNER JOIN aif_aiflines current_l
                ON current_l.aif_id = %s
                AND current_l.mercury_code = l.mercury_code

            INNER JOIN aif_aifcustomerlines current_c
                ON current_c.aif_id = %s
                AND current_c.oracle_cust_number = c.oracle_cust_number

            WHERE
                a.aif_id != %s
                AND a.nso = %s
                AND a.start_date <= %s
                AND a.end_date >= %s
        """

        params = [
            aif.aif_id,
            aif.aif_id,
            aif.aif_id,
            aif.nso,
            aif.end_date,
            aif.start_date,
        ]

    with connection.cursor() as cursor:
        cursor.execute(sql, params)
        columns = [col[0] for col in cursor.description]
        rows = cursor.fetchall()

    # convert to dict
    result = []
    for row in rows:
        result.append(dict(zip(columns, row)))

    return result


