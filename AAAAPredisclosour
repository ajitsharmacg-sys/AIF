from django.db import models

from common.models import (
    MetaCreatedAbstract,
    MetaEditedAbstract,
)


class PreDisclosureRequest(
    MetaCreatedAbstract,
    MetaEditedAbstract
):

    DISCLOSURE_TYPE_CHOICES = [
        ("ISB", "ISB"),
        ("ICB", "ICB"),
        ("ISB_ICB", "ISB & ICB"),
        ("PR_SOCIAL", "PR & Social"),
    ]

    request_id = models.AutoField(
        primary_key=True
    )

    request_name = models.CharField(
        max_length=255
    )

    disclosure_type = models.CharField(
        max_length=50,
        choices=DISCLOSURE_TYPE_CHOICES
    )

    current_step = models.PositiveIntegerField(
        default=1
    )

    comment = models.TextField(
        blank=True,
        null=True
    )

    link = models.URLField(
        blank=True,
        null=True
    )

    @property
    def current_status(self):

        latest = self.request_status.order_by(
            "-meta_created_date"
        ).first()

        return latest.status if latest else "DRAFT"

    def __str__(self):
        return str(self.request_id)


class PreDisclosureRequestLine(
    MetaCreatedAbstract,
    MetaEditedAbstract
):

    request = models.ForeignKey(
        PreDisclosureRequest,
        related_name="request_line",
        on_delete=models.CASCADE
    )

    account = models.CharField(
        max_length=255
    )

    product_group = models.CharField(
        max_length=100
    )

    setup_type = models.CharField(
        max_length=100
    )

    comment = models.TextField(
        blank=True,
        null=True
    )

    @property
    def current_status(self):

        latest = self.request_line_status.order_by(
            "-meta_created_date"
        ).first()

        return latest.status if latest else "DRAFT"

    def __str__(self):
        return str(self.pk)


class PreDisclosureRequestStatus(
    MetaCreatedAbstract
):

    STATUS_CHOICES = [

        ("DRAFT", "Draft"),

        ("IN_PROGRESS", "In Progress"),

        ("COMPLETED", "Completed"),

        ("REJECTED", "Rejected"),
    ]

    request = models.ForeignKey(
        PreDisclosureRequest,
        related_name="request_status",
