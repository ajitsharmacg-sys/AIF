from predisclosure.workflow import (
    WORKFLOW_MATRIX,
    get_next_status,
)


# =============================================================================
# Workflow Helper Methods
# =============================================================================

def get_workflow_type(predisclosure: PreDisclosure) -> str:
    """
    Returns the workflow type based on the PreDisclosure.
    """

    if predisclosure.predisclosure_type == PreDisclosureTypeChoices.PR_SOCIAL:
        return "PR_SOCIAL"

    if predisclosure.product_category == ProductCategoryChoices.ISB:
        return "ISB"

    if predisclosure.product_category == ProductCategoryChoices.ICB:
        return "ICB"

    if predisclosure.product_category == ProductCategoryChoices.ISB_ICB:
        return "ISB_ICB"

    raise ValueError("Invalid workflow configuration.")


def get_current_line_status(line: PreDisclosureLine):
    """
    Returns latest status of a line.
    """
    return (
        PreDisclosureLineStatus.objects.filter(line=line)
        .latest("meta_created_date")
    )


def get_current_step(predisclosure: PreDisclosure):
    """
    Returns current workflow step.
    """

    workflow = WORKFLOW_MATRIX[get_workflow_type(predisclosure)]

    latest_status = (
        PreDisclosureLineStatus.objects.filter(
            line__predisclosure=predisclosure
        )
        .latest("meta_created_date")
    )

    for step, status in workflow.items():
        if latest_status.status == status:
            return step

    return None


def get_all_current_line_statuses(predisclosure: PreDisclosure):
    """
    Returns latest status object for every line.
    """

    statuses = []

    for line in PreDisclosureLine.objects.filter(
        predisclosure=predisclosure
    ):
        statuses.append(get_current_line_status(line))

    return statuses


# =============================================================================
# Line Status Helpers
# =============================================================================

def update_all_lines_status(
    status: str,
    predisclosure: PreDisclosure,
    request: HttpRequest,
):
    """
    Creates the same status for every line.
    """

    statuses = []

    for line in PreDisclosureLine.objects.filter(
        predisclosure=predisclosure
    ):
        statuses.append(
            PreDisclosureLineStatus(
                line=line,
                status=status,
                meta_created_by=request.user,
            )
        )

    PreDisclosureLineStatus.objects.bulk_create(statuses)


def set_initial_line_status(
    predisclosure: PreDisclosure,
    request: HttpRequest,
):
    """
    Creates the first workflow status for every line.
    """

    workflow_type = get_workflow_type(predisclosure)

    initial_status = get_next_status(
        workflow_type,
        1,
    )

    statuses = []

    for line in PreDisclosureLine.objects.filter(
        predisclosure=predisclosure
    ):
        statuses.append(
            PreDisclosureLineStatus(
                line=line,
                status=initial_status,
                meta_created_by=request.user,
            )
        )

    PreDisclosureLineStatus.objects.bulk_create(statuses)


